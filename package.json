{
  "name": "express-mongo-gridfs",
  "version": "1.2.2",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "start": "node ./dist/index.js",
    "test": "tsx tests/router/service/unittest.test.ts",
    "test-integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/router/routes-integration.test.ts"
  },
  "author": "JUDE-893",
  "license": "ISC",
  "description": "A premium, enterprise-ready toolkit for seamless integration of Express.js and MongoDB GridFS, designed to simplify file storage and retrieval with robust features and exceptional performance.",
  "keywords": [
    "express",
    "mongodb",
    "gridfs",
    "mongoose",
    "fs",
    "file storage",
    "file retrieval",
    "node.js",
    "javascript",
    "typescript"
  ],
  "dependencies": {
    "express": "^5.2.1",
    "mongodb": "^7.1.0",
    "mongoose": "^9.3.0",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "mongodb-memory-server": "^11.0.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
